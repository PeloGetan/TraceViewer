<Window x:Class="TraceViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:TraceViewer.UI.ViewModels"
        mc:Ignorable="d"
        Title="TraceViewer"
        Icon="/Assets/TraceViewerLogo.ico"
        Height="840"
        Width="1440"
        MinHeight="640"
        MinWidth="1024"
        PreviewMouseRightButtonUp="Window_PreviewMouseRightButtonUp"
        Background="#14171C">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <viewModels:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <HierarchicalDataTemplate DataType="{x:Type viewModels:ThreadTreeItemViewModel}" ItemsSource="{Binding Children}">
            <Border x:Name="ThreadRowBorder"
                    Margin="0,2"
                    Padding="4,2"
                    CornerRadius="4"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="#E7EAF0"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Margin="8,0,0,0"
                                Padding="4,0"
                                Background="#3A4756"
                                CornerRadius="4"
                                Visibility="{Binding HasHiddenChain, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding HiddenChainBadgeText}"
                                       Foreground="#D8E2EE"
                                       FontSize="11"
                                       FontFamily="Consolas" />
                        </Border>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding DurationText}"
                               Foreground="#9FB0C3"
                               HorizontalAlignment="Right"
                               FontFamily="Consolas"
                               FontSize="12" />
                </Grid>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="ThreadRowBorder" Property="Background" Value="#2E6DA4" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
        <Style x:Key="ThreadTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#E7EAF0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="Expander"
                                          Grid.Row="0"
                                          Grid.Column="0"
                                          Width="16"
                                          Height="16"
                                          Margin="0,2,2,0"
                                          Padding="0"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          Foreground="#8D9BAA"
                                          Focusable="False"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="0">
                                                        <Path x:Name="Chevron"
                                                              Width="8"
                                                              Height="8"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Data="M 0 0 L 6 4 L 0 8 Z"
                                                              Fill="{TemplateBinding Foreground}"
                                                              Stretch="Fill"
                                                              RenderTransformOrigin="0.5,0.5">
                                                            <Path.RenderTransform>
                                                                <RotateTransform Angle="0" />
                                                            </Path.RenderTransform>
                                                        </Path>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Chevron"
                                                                    Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="90" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <Border Grid.Row="0"
                                    Grid.Column="1"
                                    Background="Transparent">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Stretch" />
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="12,0,0,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="Expanded" Handler="ThreadTreeItem_Expanded" />
            <EventSetter Event="Collapsed" Handler="ThreadTreeItem_Collapsed" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="220" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="14"
                    Margin="0,0,0,12"
                    Background="#1C2128"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#C7D2DF"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Padding="12,6"
                            Margin="12,0,0,0"
                            Click="OpenTraceButton_Click"
                            Background="#2E6DA4"
                            BorderBrush="#2E6DA4"
                            Foreground="#F8FAFC"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Content="Open Trace" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#1C2128"
                    CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Frame Timeline"
                                       Foreground="#F1F5F9"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="12,2,0,0"
                                       Text="Wheel zoom, right-drag to pan"
                                       Foreground="#8D9BAA"
                                       FontSize="12" />
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1"
                            Margin="0,14,0,0"
                            BorderBrush="#2A313A"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="#171B21"
                            Padding="12">
                        <Grid>
                            <ScrollViewer x:Name="FrameTimelineScrollViewer"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          PanningMode="HorizontalOnly"
                                          PreviewMouseWheel="FrameTimelineScrollViewer_PreviewMouseWheel"
                                          PreviewMouseRightButtonDown="FrameTimelineScrollViewer_PreviewMouseRightButtonDown"
                                          PreviewMouseRightButtonUp="FrameTimelineScrollViewer_PreviewMouseRightButtonUp"
                                          LostMouseCapture="FrameTimelineScrollViewer_LostMouseCapture"
                                          PreviewMouseMove="FrameTimelineScrollViewer_PreviewMouseMove">
                                <ItemsControl ItemsSource="{Binding FrameBars}"
                                              VerticalAlignment="Bottom">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Bottom" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:FrameBarViewModel}">
                                            <Button Width="{Binding DataContext.FrameBarWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Margin="0,0,2,0"
                                                    Height="{Binding Height}"
                                                    VerticalAlignment="Bottom"
                                                    Click="FrameBar_Click"
                                                    Tag="{Binding}"
                                                    ToolTip="{Binding Tooltip}"
                                                    BorderThickness="0"
                                                    Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#9EC5FE" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="2" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#F59E0B" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Text="Load a local .utrace to populate frame bars."
                                       Foreground="#7F8B98"
                                       FontSize="13"
                                       Visibility="{Binding HasFrameBars, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#1C2128"
                        CornerRadius="10"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Active Threads"
                                       Foreground="#F1F5F9"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="12,2,0,0"
                                       Text="Shift+click selects range, Shift+expand opens full subtree, Ctrl+C copies names"
                                       Foreground="#8D9BAA"
                                       FontSize="12" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,14,0,0"
                                BorderBrush="#2A313A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="#171B21"
                                Padding="8">
                            <Grid>
                                <TreeView x:Name="ThreadTreeView"
                                          ItemsSource="{Binding ThreadItems}"
                                          ItemContainerStyle="{StaticResource ThreadTreeItemStyle}"
                                          SelectedItemChanged="ThreadTree_SelectedItemChanged"
                                          PreviewMouseLeftButtonDown="ThreadTree_PreviewMouseLeftButtonDown"
                                          PreviewKeyDown="ThreadTree_PreviewKeyDown"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Foreground="#E7EAF0" />
                                <TextBlock Text="Only threads with activity in the selected frame will appear here."
                                           Foreground="#7F8B98"
                                           FontSize="13"
                                           Visibility="{Binding HasThreadItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="#11151A" />

                <Border Grid.Column="2"
                        Background="#1C2128"
                        CornerRadius="10"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Function Details"
                                       Foreground="#F1F5F9"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="12,2,0,0"
                                       Text="Selected node metadata and clipped frame timing"
                                       Foreground="#8D9BAA"
                                       FontSize="12" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,14,0,0"
                                BorderBrush="#2A313A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="#171B21"
                                Padding="12">
                            <Grid>
                                <ItemsControl ItemsSource="{Binding Details}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:FunctionDetailItemViewModel}">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Label}"
                                                           Foreground="#8D9BAA"
                                                           FontSize="12" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           Foreground="#E7EAF0"
                                                           FontSize="12"
                                                           FontFamily="Consolas"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Select a function node to inspect inclusive/exclusive timing and frame clipping details."
                                           Foreground="#7F8B98"
                                           FontSize="13"
                                           Visibility="{Binding HasSelectedNode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4"
                    Margin="0,12,0,0"
                    Padding="10,8"
                    Background="#1C2128"
                    CornerRadius="10">
                <TextBlock Foreground="#8D9BAA"
                           FontSize="12"
                           HorizontalAlignment="Center">
                    <Run Text="Author: PeloGetan  |  Repository: " />
                    <Hyperlink NavigateUri="https://github.com/PeloGetan/TraceViewer"
                               RequestNavigate="RepositoryLink_RequestNavigate">
                        <Run Text="github.com/PeloGetan/TraceViewer" />
                    </Hyperlink>
                </TextBlock>
            </Border>
        </Grid>

        <Border Background="#A014171C"
                CornerRadius="12"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Border Width="280"
                        Padding="20"
                        Background="#1C2128"
                        BorderBrush="#314052"
                        BorderThickness="1"
                        CornerRadius="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Loading trace..."
                                   Foreground="#F1F5F9"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding StatusText}"
                                   Foreground="#9FB0C3"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        <ProgressBar Margin="0,16,0,0"
                                     Height="8"
                                     IsIndeterminate="True" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
